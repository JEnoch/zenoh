use async_std::sync::{Arc, RwLock};
use log::{debug, trace, warn};
use rusqlite::backup::Backup;
use rusqlite::types::{FromSql, FromSqlError, FromSqlResult, ToSqlOutput, ValueRef};
use rusqlite::{params, Connection, OptionalExtension, Statement, ToSql, NO_PARAMS};
use std::path::PathBuf;
use std::str::FromStr;
use zenoh::net::ZInt;
use zenoh::{Timestamp, TimestampID, ZError, ZErrorKind, ZResult};
use zenoh_util::{zerror, zerror2};

const DB_FILENAME: &str = ".zenoh_datainfo";

const INSERT_STMT: &str =
    "INSERT INTO zenoh (path, deleted, encoding, timestamp) VALUES (?1, ?2, ?3, ?4)";
const DELETE_STMT: &str = "DELETE FROM zenoh WHERE path=?1";
const SELECT_ALL_STMT: &str = "SELECT encoding, timestamp FROM zenoh WHERE path=?1";
const SELECT_TS_STMT: &str = "SELECT timestamp FROM zenoh WHERE path=?1";

#[derive(Debug)]
struct Entry {
    path: String,
    deleted: bool,
    encoding: ZInt,
    timestamp: Timestamp,
}

pub(crate) struct DataInfoMgr {
    mem_db: Arc<RwLock<Connection>>,
    bak_db: Arc<RwLock<Connection>>,
}

impl DataInfoMgr {
    pub(crate) fn new(base_dir: &str) -> ZResult<Self> {
        let mut backup_file = PathBuf::from(base_dir);
        backup_file.push(DB_FILENAME);
        let backup_file_display = backup_file.display();

        // Connection to the backup database (i.e. file)
        let bak_db = if backup_file.exists() {
            trace!("Open db {}", backup_file_display);
            Connection::open(&backup_file).map_err(|e| {
                zerror2!(ZErrorKind::Other {
                    descr: format!(
                        "Failed to open data-info file {} : {}",
                        backup_file_display, e
                    )
                })
            })?
        } else {
            // create the databse
            trace!("Create db {}", backup_file_display);
            let db = Connection::open(&backup_file).unwrap();
            db.execute(
                "CREATE TABLE zenoh (
                  path            VARCHAR(1024) PRIMARY KEY,
                  deleted         INT,
                  encoding        INT,
                  timestamp       TEXT NOT NULL
                  )",
                NO_PARAMS,
            )
            .map_err(|e| {
                zerror2!(ZErrorKind::Other {
                    descr: format!(
                        "Failed to create data-info file {} : {}",
                        backup_file_display, e
                    )
                })
            })?;
            db
        };

        // Connection to the in-memory database
        let mut mem_db = Connection::open_in_memory().map_err(|e| {
            zerror2!(ZErrorKind::Other {
                descr: format!("Failed to create in-memory db for data-info: {}", e)
            })
        })?;

        // Restore in-memory database from backup database
        trace!("Restore db {}", backup_file_display);
        Backup::new(&bak_db, &mut mem_db)
            .and_then(|b| b.run_to_completion(256, std::time::Duration::from_millis(0), None))
            .map_err(|e| {
                zerror2!(ZErrorKind::Other {
                    descr: format!(
                        "Failed to restore data-info db from {} : {}",
                        backup_file_display, e
                    )
                })
            })?;

        // Prepare cached statements
        let _ = mem_db.prepare_cached(INSERT_STMT).map_err(|e| {
            zerror2!(ZErrorKind::Other {
                descr: format!("Failed to prepare put statement for data-info db : {}", e)
            })
        })?;

        let _ = mem_db.prepare_cached(DELETE_STMT).map_err(|e| {
            zerror2!(ZErrorKind::Other {
                descr: format!("Failed to prepare del statement for data-info db : {}", e)
            })
        })?;

        let _ = mem_db.prepare_cached(SELECT_ALL_STMT).map_err(|e| {
            zerror2!(ZErrorKind::Other {
                descr: format!(
                    "Failed to prepare get_ts statement for data-info db : {}",
                    e
                )
            })
        })?;

        let _ = mem_db.prepare_cached(SELECT_TS_STMT).map_err(|e| {
            zerror2!(ZErrorKind::Other {
                descr: format!(
                    "Failed to prepare get_ts statement for data-info db : {}",
                    e
                )
            })
        })?;

        Ok(DataInfoMgr {
            mem_db: Arc::new(RwLock::new(mem_db)),
            bak_db: Arc::new(RwLock::new(bak_db)),
        })
    }
    /*
