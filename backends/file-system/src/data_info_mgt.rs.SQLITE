// Note: no choice but to wrap the Timestamp to implement the ToSql/FromSql traits for it
// (as both type and traits are in different crates).
struct TsWrapper {
    ts: Timestamp,
}

impl ToSql for TsWrapper {
    fn to_sql(&self) -> rusqlite::Result<ToSqlOutput<'_>> {
        Ok(ToSqlOutput::from(self.ts.to_string()))
    }
}

impl FromSql for TsWrapper {
    fn column_result(value: ValueRef<'_>) -> FromSqlResult<Self> {
        let ts = Timestamp::from_str(value.as_str()?).map_err(|_| FromSqlError::InvalidType)?;
        Ok(TsWrapper { ts })
    }
}
